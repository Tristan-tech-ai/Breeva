# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# APIs
VITE_OPENROUTESERVICE_API_KEY=your_ors_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# Upstash Redis (server-side only - don't expose to client)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ============================================
# VAYU Engine — Environment Variables
# ============================================

# --- VAYU MVP (Phase 0) ---
# Open-Meteo: TIDAK perlu API key — API publik
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- VAYU Phase 0.5 ---
TOMTOM_API_KEY=your_tomtom_key
WAQI_TOKEN=your_waqi_token

# --- VAYU Phase 1+ ---
IQAIR_API_KEY=your_iqair_community_key
OPENTOPO_API_KEY=your_opentopography_key

# --- VAYU Phase 2+ ---
CDSE_CLIENT_ID=your_copernicus_client_id
CDSE_CLIENT_SECRET=your_copernicus_secret
NASA_EARTHDATA_TOKEN=your_nasa_token
